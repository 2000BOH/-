# 이 파일을 복사해 `.env` 또는 `.env.local` 로 저장한 뒤 값을 채우세요.
# `.env` / `.env.local` 은 Git에 올라가지 않습니다 (.gitignore).

# --- Supabase (여러 PC·배포 URL에서 같은 데이터를 쓰려면 필수) ---
# Vercel → Project → Settings → Environment Variables 에도 동일 이름으로 넣고 Redeploy 하세요.
# 없으면 브라우저 localStorage만 사용하며, localhost 와 vercel.app 은 서로 다른 데이터입니다.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# Google AI Studio (Gemini) API 키 — Vite dev/preview 서버에서만 사용, 브라우저 번들에 포함되지 않습니다.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (대안 이름들, 하나만 있으면 됩니다)
# GOOGLE_API_KEY=
# VITE_GEMINI_API_KEY=

# 선택: 우선 시도할 모델 (기본 gemini-2.0-flash). 404 시 서버가 다른 모델·API 버전으로 자동 재시도합니다.
# VITE_GEMINI_MODEL=gemini-2.0-flash
# VITE_GEMINI_MODEL=gemini-1.5-flash-002
