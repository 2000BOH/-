# 이 파일을 복사해 `.env` 또는 `.env.local` 로 저장한 뒤 값을 채우세요.
# `.env` / `.env.local` 은 Git에 올라가지 않습니다 (.gitignore).

# Google AI Studio (Gemini) API 키 — Vite dev/preview 서버에서만 사용, 브라우저 번들에 포함되지 않습니다.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (대안 이름들, 하나만 있으면 됩니다)
# GOOGLE_API_KEY=
# VITE_GEMINI_API_KEY=

# 선택: 우선 시도할 모델 (기본 gemini-2.0-flash). 404 시 서버가 다른 모델·API 버전으로 자동 재시도합니다.
# VITE_GEMINI_MODEL=gemini-2.0-flash
# VITE_GEMINI_MODEL=gemini-1.5-flash-002
